# Admin frontend (streamhub-web) — Vercel Production env.
# Set these in the Vercel project's Environment Variables (Production).

# The public HTTPS URL of the backend API (the CloudFront distribution that fronts the EC2 API).
NEXT_PUBLIC_API_BASE_URL=https://dpdtwguq8ke3x.cloudfront.net

# NextAuth (Auth.js v5). trustHost is already enabled in code; AUTH_URL/NEXTAUTH_URL is optional
# but recommended. The secret signs the session JWT — generate with: openssl rand -base64 32
NEXTAUTH_URL=https://your-admin-project.vercel.app
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
