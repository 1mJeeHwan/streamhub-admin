# Public media frontend (streamhub-user-web) — Vercel Production env.
# Set this in the Vercel project's Environment Variables (Production).

# The public HTTPS URL of the backend API (the CloudFront distribution that fronts the EC2 API).
NEXT_PUBLIC_API_BASE=https://dpdtwguq8ke3x.cloudfront.net

# Kakao Maps JavaScript key — enables the church-finder map (NEXT_PUBLIC_KAKAO_MAP_KEY).
# Kakao Developers → My Application → JavaScript key; register the Vercel domain under Web platform.
NEXT_PUBLIC_KAKAO_MAP_KEY=your-kakao-javascript-key
