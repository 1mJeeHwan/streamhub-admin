# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored (contains secrets).

aws_region     = "ap-northeast-2"
s3_bucket_name = "streamhub-media-CHANGE-ME-12345" # must be globally unique

# Secrets — use strong values.
db_password = "change-me-strong-password"
jwt_secret  = "change-me-to-a-long-random-string-at-least-48-chars-0123456789"

# Your SSH public key (so you can ssh into the EC2 host).
ssh_public_key = "ssh-ed25519 AAAA... your-key"

# Lock these down to your IP for safety (e.g. "203.0.113.4/32").
ssh_ingress_cidr = "0.0.0.0/0"
api_ingress_cidr = "0.0.0.0/0"
